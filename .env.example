# Supabase principal usado pelo app.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Live score provider: espn, worldcup26, football-data, manual or api-football.
LIVE_SCORE_PROVIDER=espn

# Optional OpenFootball source URL.
OPENFOOTBALL_WORLD_CUP_2026_URL=

# Optional API-Football configuration.
API_FOOTBALL_KEY=
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_WORLD_CUP_SEASON=2026

# Optional football-data.org configuration.
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION_CODE=WC

# Secret used by score sync routes or cron calls.
SCORES_SYNC_SECRET=your_scores_sync_secret

# Optional local score sources.
LOCAL_SCORE_SCRAPER_URL=
WORLDCUP26_API_BASE_URL=
SCORES_ACTIVE_SYNC_INTERVAL_SECONDS=30
LOCAL_SCORE_SOURCE=espn
LOCAL_SCORE_API_URL=
LOCAL_SCORE_POLL_INTERVAL_SECONDS=30
ESPN_SCOREBOARD_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world
