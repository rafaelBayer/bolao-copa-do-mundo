# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key for browser-safe authentication.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key.
# Usada somente em scripts locais/server-side. Nunca expor no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional apenas para scripts locais/server-side.
# Use "syo" para o Supabase antigo/original ou "public" para o Supabase publico/MVP.
# Se ficar vazio, os scripts usam as variaveis padrao acima.
SUPABASE_TARGET=

# Supabase 1 - SYO Bolao / original.
# Usado apenas por scripts locais/server-side.
SYO_SUPABASE_URL=
SYO_SUPABASE_ANON_KEY=
SYO_SUPABASE_SERVICE_ROLE_KEY=

# Supabase 2 - Publico / MVP.
# Usado apenas por scripts locais/server-side.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_SUPABASE_SERVICE_ROLE_KEY=

# Optional OpenFootball source URL.
# Usada somente pelo script fetch:worldcup. Nao usar NEXT_PUBLIC_.
OPENFOOTBALL_WORLD_CUP_2026_URL=

# Legacy API-Football / API-Sports key.
# Nao recomendado como provider principal de live score. Nunca usar NEXT_PUBLIC_.
API_FOOTBALL_KEY=

# Optional API-Football competition mapping. Defaults: league=1, season=2026.
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=
API_FOOTBALL_WORLD_CUP_SEASON=

# Live score provider: espn, worldcup26, football-data, manual or api-football.
# Provider principal para score/gols minuto a minuto pela ESPN.
# Fallback seguro/emergencial: manual.
LIVE_SCORE_PROVIDER=espn
ESPN_SCOREBOARD_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world

# Fallback/apoio para placar da Copa, se necessario.
WORLDCUP26_API_BASE_URL=https://worldcup26.ir

# Intervalo recomendado durante jogos ativos.
SCORES_ACTIVE_SYNC_INTERVAL_SECONDS=30

# Legacy football-data.org provider. Nao recomendado para live score principal.
# Nunca usar NEXT_PUBLIC_.
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION_CODE=WC

# Secret used by /api/scores/sync and cron calls.
SCORES_SYNC_SECRET=

# Fonte local emergencial para placar da Copa 2026.
# Usada apenas pelo script npm run scores:watch:local.
LOCAL_SCORE_SOURCE=espn
LOCAL_SCORE_POLL_INTERVAL_SECONDS=30
